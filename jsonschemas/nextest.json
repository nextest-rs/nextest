{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NextestConfigDeserialize",
  "type": "object",
  "properties": {
    "experimental": {
      "$ref": "#/definitions/ExperimentalDeserialize"
    },
    "nextest-version": {
      "anyOf": [
        {
          "$ref": "#/definitions/NextestVersionDeserialize"
        },
        {
          "type": "null"
        }
      ]
    },
    "profile": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/definitions/CustomProfileImpl"
      }
    },
    "script": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/SetupScriptConfig"
      }
    },
    "scripts": {
      "$ref": "#/definitions/ScriptConfig"
    },
    "store": {
      "anyOf": [
        {
          "$ref": "#/definitions/StoreConfigImpl"
        },
        {
          "type": "null"
        }
      ]
    },
    "test-groups": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/TestGroupConfig"
      }
    }
  },
  "additionalProperties": false,
  "x-tombi-toml-version": "v1.1.0",
  "definitions": {
    "ArchiveConfig": {
      "description": "Configuration for archives.",
      "type": "object",
      "properties": {
        "include": {
          "description": "Files to include in the archive.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ArchiveInclude"
          }
        }
      },
      "additionalProperties": false
    },
    "ArchiveInclude": {
      "description": "Type for the archive-include key.\n\n# Notes\n\nThis is `deny_unknown_fields` because if we take additional arguments in the future, they're likely to change semantics in an incompatible way.",
      "type": "object",
      "required": [
        "path",
        "relative-to"
      ],
      "properties": {
        "depth": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0.0
            },
            {
              "type": "string",
              "enum": [
                "infinite"
              ]
            }
          ]
        },
        "on-missing": {
          "$ref": "#/definitions/ArchiveIncludeOnMissing"
        },
        "path": {
          "type": "string"
        },
        "relative-to": {
          "$ref": "#/definitions/ArchiveRelativeTo"
        }
      },
      "additionalProperties": false
    },
    "ArchiveIncludeOnMissing": {
      "description": "What to do when an archive-include path is missing.",
      "oneOf": [
        {
          "description": "Ignore and continue.",
          "type": "string",
          "enum": [
            "ignore"
          ]
        },
        {
          "description": "Warn and continue.",
          "type": "string",
          "enum": [
            "warn"
          ]
        },
        {
          "description": "Produce an error.",
          "type": "string",
          "enum": [
            "error"
          ]
        }
      ]
    },
    "ArchiveRelativeTo": {
      "description": "Defines the base of the path",
      "oneOf": [
        {
          "description": "Path starts at the target directory",
          "type": "string",
          "enum": [
            "target"
          ]
        }
      ]
    },
    "BenchConfig": {
      "description": "Benchmark-specific configuration (deserialized form with optional fields).",
      "type": "object",
      "properties": {
        "global-timeout": {
          "description": "Global timeout for benchmarks.",
          "type": [
            "string",
            "null"
          ]
        },
        "slow-timeout": {
          "description": "Slow timeout for benchmarks.",
          "anyOf": [
            {
              "$ref": "#/definitions/SlowTimeout"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "CustomProfileImpl": {
      "type": "object",
      "properties": {
        "archive": {
          "anyOf": [
            {
              "$ref": "#/definitions/ArchiveConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "bench": {
          "anyOf": [
            {
              "$ref": "#/definitions/BenchConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "default-filter": {
          "description": "The default set of tests run by `cargo nextest run`.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "fail-fast": {
          "anyOf": [
            {
              "$ref": "#/definitions/MaxFail"
            },
            {
              "type": "null"
            }
          ]
        },
        "failure-output": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/TestOutputDisplay"
            },
            {
              "type": "null"
            }
          ]
        },
        "final-status-level": {
          "anyOf": [
            {
              "$ref": "#/definitions/FinalStatusLevel"
            },
            {
              "type": "null"
            }
          ]
        },
        "flaky-result": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/FlakyResult"
            },
            {
              "type": "null"
            }
          ]
        },
        "global-timeout": {
          "type": [
            "string",
            "null"
          ]
        },
        "inherits": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "junit": {
          "$ref": "#/definitions/JunitImpl"
        },
        "leak-timeout": {
          "anyOf": [
            {
              "$ref": "#/definitions/LeakTimeout"
            },
            {
              "type": "null"
            }
          ]
        },
        "overrides": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/DeserializedOverride"
          }
        },
        "retries": {
          "anyOf": [
            {
              "$ref": "#/definitions/RetryPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "run-extra-args": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/DeserializedProfileScriptConfig"
          }
        },
        "slow-timeout": {
          "anyOf": [
            {
              "$ref": "#/definitions/SlowTimeout"
            },
            {
              "type": "null"
            }
          ]
        },
        "status-level": {
          "anyOf": [
            {
              "$ref": "#/definitions/StatusLevel"
            },
            {
              "type": "null"
            }
          ]
        },
        "success-output": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/TestOutputDisplay"
            },
            {
              "type": "null"
            }
          ]
        },
        "test-threads": {
          "anyOf": [
            {
              "$ref": "#/definitions/TestThreads"
            },
            {
              "type": "null"
            }
          ]
        },
        "threads-required": {
          "anyOf": [
            {
              "$ref": "#/definitions/ThreadsRequired"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "CustomTestGroup": {
      "description": "Represents a custom test group.",
      "type": "string"
    },
    "DeserializedJunitOutput": {
      "type": "object",
      "properties": {
        "flaky-fail-status": {
          "anyOf": [
            {
              "$ref": "#/definitions/JunitFlakyFailStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "store-failure-output": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "store-success-output": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "DeserializedOverride": {
      "description": "Deserialized form of profile overrides before compilation.",
      "type": "object",
      "properties": {
        "bench": {
          "description": "Benchmark-specific overrides.",
          "allOf": [
            {
              "$ref": "#/definitions/DeserializedOverrideBench"
            }
          ]
        },
        "default-filter": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "failure-output": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/TestOutputDisplay"
            },
            {
              "type": "null"
            }
          ]
        },
        "filter": {
          "description": "The filterset to match against.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "flaky-result": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/FlakyResult"
            },
            {
              "type": "null"
            }
          ]
        },
        "junit": {
          "$ref": "#/definitions/DeserializedJunitOutput"
        },
        "leak-timeout": {
          "anyOf": [
            {
              "$ref": "#/definitions/LeakTimeout"
            },
            {
              "type": "null"
            }
          ]
        },
        "platform": {
          "description": "The host and/or target platforms to match against.",
          "allOf": [
            {
              "$ref": "#/definitions/PlatformStrings"
            }
          ]
        },
        "priority": {
          "description": "Overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/TestPriority"
            },
            {
              "type": "null"
            }
          ]
        },
        "retries": {
          "description": "Retry policy for this override.",
          "anyOf": [
            {
              "$ref": "#/definitions/RetryPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "run-extra-args": {
          "default": null,
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "slow-timeout": {
          "anyOf": [
            {
              "$ref": "#/definitions/SlowTimeout"
            },
            {
              "type": "null"
            }
          ]
        },
        "success-output": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/TestOutputDisplay"
            },
            {
              "type": "null"
            }
          ]
        },
        "test-group": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/CustomTestGroup"
            },
            {
              "type": "null"
            }
          ]
        },
        "threads-required": {
          "anyOf": [
            {
              "$ref": "#/definitions/ThreadsRequired"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "DeserializedOverrideBench": {
      "description": "Deserialized form of benchmark-specific overrides.",
      "type": "object",
      "properties": {
        "slow-timeout": {
          "anyOf": [
            {
              "$ref": "#/definitions/SlowTimeout"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "DeserializedProfileScriptConfig": {
      "description": "Deserialized form of profile-specific script configuration before compilation.",
      "type": "object",
      "properties": {
        "filter": {
          "description": "The filterset to match against.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "list-wrapper": {
          "description": "The wrapper script to run at list time.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "description": "The host and/or target platforms to match against.",
          "allOf": [
            {
              "$ref": "#/definitions/PlatformStrings"
            }
          ]
        },
        "run-wrapper": {
          "description": "The wrapper script to run at run time.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "setup": {
          "description": "The setup script or scripts to run.",
          "default": [],
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ExperimentalDeserialize": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "setup-scripts",
              "wrapper-scripts",
              "benchmarks"
            ]
          }
        },
        {
          "type": "object",
          "properties": {
            "benchmarks": {
              "type": "boolean"
            },
            "setup-scripts": {
              "type": "boolean"
            },
            "wrapper-scripts": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "FinalStatusLevel": {
      "description": "Status level to show at the end of test runs in the reporter output.\n\nStatus levels are incremental.\n\nThis differs from [`StatusLevel`] in two ways: * It has a \"flaky\" test indicator that's different from \"retry\" (though \"retry\" works as an alias.) * It has a different ordering: skipped tests are prioritized over passing ones.",
      "oneOf": [
        {
          "description": "No output.",
          "type": "string",
          "enum": [
            "none"
          ]
        },
        {
          "description": "Only output test failures.",
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        {
          "description": "Output flaky tests.",
          "type": "string",
          "enum": [
            "flaky"
          ]
        },
        {
          "description": "Output information about slow tests, and all variants above.",
          "type": "string",
          "enum": [
            "slow"
          ]
        },
        {
          "description": "Output skipped tests in addition to all variants above.",
          "type": "string",
          "enum": [
            "skip"
          ]
        },
        {
          "description": "Output leaky tests in addition to all variants above.",
          "type": "string",
          "enum": [
            "leak"
          ]
        },
        {
          "description": "Output passing tests in addition to all variants above.",
          "type": "string",
          "enum": [
            "pass"
          ]
        },
        {
          "description": "Currently has the same meaning as [`Pass`](Self::Pass).",
          "type": "string",
          "enum": [
            "all"
          ]
        }
      ]
    },
    "FlakyResult": {
      "description": "Controls whether a flaky test is treated as a pass or a failure.",
      "oneOf": [
        {
          "description": "The test is marked as failed.",
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        {
          "description": "The test is marked as passed.",
          "type": "string",
          "enum": [
            "pass"
          ]
        }
      ]
    },
    "JunitFlakyFailStatus": {
      "description": "Controls how flaky-fail tests are reported in JUnit XML output.\n\nFlaky-fail tests are tests that eventually passed on retry but are configured with `flaky-result = \"fail\"`. This setting controls whether they appear as failures or successes in the JUnit report.",
      "oneOf": [
        {
          "description": "Report flaky-fail tests as failures with `<failure>` and `<flakyFailure>` elements.",
          "type": "string",
          "enum": [
            "failure"
          ]
        },
        {
          "description": "Report flaky-fail tests as successes, identical to flaky-pass tests.",
          "type": "string",
          "enum": [
            "success"
          ]
        }
      ]
    },
    "JunitImpl": {
      "type": "object",
      "properties": {
        "flaky-fail-status": {
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/JunitFlakyFailStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "path": {
          "default": null,
          "type": "string"
        },
        "report-name": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "store-failure-output": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "store-success-output": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "LeakTimeout": {
      "title": "LeakTimeout",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "period"
          ],
          "properties": {
            "period": {
              "type": "string"
            },
            "result": {
              "$ref": "#/definitions/LeakTimeoutResult"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "LeakTimeoutResult": {
      "description": "The result of controlling leak timeout behavior.",
      "oneOf": [
        {
          "description": "The test is marked as failed.",
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        {
          "description": "The test is marked as passed.",
          "type": "string",
          "enum": [
            "pass"
          ]
        }
      ]
    },
    "MaxFail": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "required": [
            "max-fail"
          ],
          "properties": {
            "max-fail": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1.0
                },
                {
                  "type": "string",
                  "enum": [
                    "all"
                  ]
                }
              ]
            },
            "terminate": {
              "$ref": "#/definitions/TerminateMode"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "NextestVersionDeserialize": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "recommended": {
              "type": "string"
            },
            "required": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "PlatformStrings": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "host": {
              "type": [
                "string",
                "null"
              ]
            },
            "target": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "RetryPolicy": {
      "title": "RetryPolicy",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0.0
        },
        {
          "type": "object",
          "required": [
            "backoff",
            "count"
          ],
          "properties": {
            "backoff": {
              "type": "string",
              "const": "fixed"
            },
            "count": {
              "type": "integer",
              "minimum": 0.0
            },
            "delay": {
              "type": "string"
            },
            "jitter": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "backoff",
            "count",
            "delay"
          ],
          "properties": {
            "backoff": {
              "type": "string",
              "const": "exponential"
            },
            "count": {
              "type": "integer",
              "minimum": 0.0
            },
            "delay": {
              "type": "string"
            },
            "jitter": {
              "type": "boolean"
            },
            "max-delay": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ScriptCommand": {
      "title": "ScriptCommand",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        {
          "type": "object",
          "required": [
            "command-line"
          ],
          "properties": {
            "command-line": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "minItems": 1
                }
              ]
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "relative-to": {
              "$ref": "#/definitions/ScriptCommandRelativeTo"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ScriptCommandRelativeTo": {
      "description": "The directory to interpret a [`ScriptCommand`] as relative to, in case it is a relative path.\n\nIf specified, the program will be joined with the provided path.",
      "oneOf": [
        {
          "description": "Do not join the program with any path.",
          "type": "string",
          "enum": [
            "none"
          ]
        },
        {
          "description": "Join the program with the workspace root.",
          "type": "string",
          "enum": [
            "workspace-root"
          ]
        },
        {
          "description": "Join the program with the target directory.",
          "type": "string",
          "enum": [
            "target"
          ]
        }
      ]
    },
    "ScriptConfig": {
      "description": "The scripts defined in nextest configuration.",
      "type": "object",
      "properties": {
        "setup": {
          "description": "The setup scripts defined in nextest's configuration.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/SetupScriptConfig"
          }
        },
        "wrapper": {
          "description": "The wrapper scripts defined in nextest's configuration.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/WrapperScriptConfig"
          }
        }
      },
      "additionalProperties": false
    },
    "SetupScriptConfig": {
      "description": "Deserialized form of setup script configuration before compilation.\n\nThis is defined as a top-level element.",
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "capture-stderr": {
          "description": "Whether to capture standard error for this command.",
          "default": false,
          "type": "boolean"
        },
        "capture-stdout": {
          "description": "Whether to capture standard output for this command.",
          "default": false,
          "type": "boolean"
        },
        "command": {
          "description": "The command to run. The first element is the program and the second element is a list of arguments.",
          "allOf": [
            {
              "$ref": "#/definitions/ScriptCommand"
            }
          ]
        },
        "junit": {
          "description": "JUnit configuration for this script.",
          "allOf": [
            {
              "$ref": "#/definitions/SetupScriptJunitConfig"
            }
          ]
        },
        "leak-timeout": {
          "description": "An optional leak timeout for this command.",
          "anyOf": [
            {
              "$ref": "#/definitions/LeakTimeout"
            },
            {
              "type": "null"
            }
          ]
        },
        "slow-timeout": {
          "description": "An optional slow timeout for this command.",
          "anyOf": [
            {
              "$ref": "#/definitions/SlowTimeout"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "SetupScriptJunitConfig": {
      "description": "A JUnit override configuration.",
      "type": "object",
      "properties": {
        "store-failure-output": {
          "description": "Whether to store failing output.\n\nDefaults to true.",
          "default": true,
          "type": "boolean"
        },
        "store-success-output": {
          "description": "Whether to store successful output.\n\nDefaults to true.",
          "default": true,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "SlowTimeout": {
      "title": "SlowTimeout",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": [
            "period"
          ],
          "properties": {
            "grace-period": {
              "type": "string"
            },
            "on-timeout": {
              "$ref": "#/definitions/SlowTimeoutResult"
            },
            "period": {
              "type": "string"
            },
            "terminate-after": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1.0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "SlowTimeoutResult": {
      "description": "The result of controlling slow timeout behavior.\n\nIn most situations a timed out test should be marked failing. However, there are certain classes of tests which are expected to run indefinitely long, like fuzzing, which explores a huge state space. For these tests it's nice to be able to treat a timeout as a success since they generally check for invariants and other properties of the code under test during their execution. A timeout in this context doesn't mean that there are no failing inputs, it just means that they weren't found up until that moment, which is still valuable information.",
      "oneOf": [
        {
          "description": "The test is marked as failed.",
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        {
          "description": "The test is marked as passed.",
          "type": "string",
          "enum": [
            "pass"
          ]
        }
      ]
    },
    "StatusLevel": {
      "description": "Status level to show in the reporter output.\n\nStatus levels are incremental: each level causes all the statuses listed above it to be output. For example, [`Slow`](Self::Slow) implies [`Retry`](Self::Retry) and [`Fail`](Self::Fail).",
      "oneOf": [
        {
          "description": "No output.",
          "type": "string",
          "enum": [
            "none"
          ]
        },
        {
          "description": "Only output test failures.",
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        {
          "description": "Output retries and failures.",
          "type": "string",
          "enum": [
            "retry"
          ]
        },
        {
          "description": "Output information about slow tests, and all variants above.",
          "type": "string",
          "enum": [
            "slow"
          ]
        },
        {
          "description": "Output information about leaky tests, and all variants above.",
          "type": "string",
          "enum": [
            "leak"
          ]
        },
        {
          "description": "Output passing tests in addition to all variants above.",
          "type": "string",
          "enum": [
            "pass"
          ]
        },
        {
          "description": "Output skipped tests in addition to all variants above.",
          "type": "string",
          "enum": [
            "skip"
          ]
        },
        {
          "description": "Currently has the same meaning as [`Skip`](Self::Skip).",
          "type": "string",
          "enum": [
            "all"
          ]
        }
      ]
    },
    "StoreConfigImpl": {
      "type": "object",
      "properties": {
        "dir": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "TerminateMode": {
      "description": "Mode for terminating running tests when max-fail is exceeded.",
      "oneOf": [
        {
          "description": "Wait for running tests to complete (default)",
          "type": "string",
          "enum": [
            "wait"
          ]
        },
        {
          "description": "Terminate running tests immediately",
          "type": "string",
          "enum": [
            "immediate"
          ]
        }
      ]
    },
    "TestGroupConfig": {
      "description": "Configuration for a test group.",
      "type": "object",
      "required": [
        "max-threads"
      ],
      "properties": {
        "max-threads": {
          "description": "The maximum number of threads allowed for this test group.",
          "allOf": [
            {
              "$ref": "#/definitions/TestThreads"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "TestOutputDisplay": {
      "description": "When to display test output in the reporter.",
      "oneOf": [
        {
          "description": "Show output immediately on execution completion.\n\nThis is the default for failing tests.",
          "type": "string",
          "enum": [
            "immediate"
          ]
        },
        {
          "description": "Show output immediately, and at the end of a test run.",
          "type": "string",
          "enum": [
            "immediate-final"
          ]
        },
        {
          "description": "Show output at the end of execution.",
          "type": "string",
          "enum": [
            "final"
          ]
        },
        {
          "description": "Never show output.",
          "type": "string",
          "enum": [
            "never"
          ]
        }
      ]
    },
    "TestPriority": {
      "description": "A test priority: a number between -100 and 100.\n\nThe sort order is from highest to lowest priority.",
      "type": "integer",
      "format": "int8",
      "maximum": 100.0,
      "minimum": -100.0
    },
    "TestThreads": {
      "oneOf": [
        {
          "type": "integer",
          "not": {
            "const": 0
          }
        },
        {
          "type": "string",
          "enum": [
            "num-cpus"
          ]
        }
      ]
    },
    "ThreadsRequired": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1.0
        },
        {
          "type": "string",
          "enum": [
            "num-cpus",
            "num-test-threads"
          ]
        }
      ]
    },
    "WrapperScriptConfig": {
      "description": "Deserialized form of wrapper script configuration before compilation.\n\nThis is defined as a top-level element.",
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "description": "The command to run.",
          "allOf": [
            {
              "$ref": "#/definitions/ScriptCommand"
            }
          ]
        },
        "target-runner": {
          "description": "How this script interacts with a configured target runner, if any. Defaults to ignoring the target runner.",
          "allOf": [
            {
              "$ref": "#/definitions/WrapperScriptTargetRunner"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "WrapperScriptTargetRunner": {
      "description": "Interaction of wrapper script with a configured target runner.",
      "oneOf": [
        {
          "description": "The target runner is ignored. This is the default.",
          "type": "string",
          "enum": [
            "ignore"
          ]
        },
        {
          "description": "The target runner overrides the wrapper.",
          "type": "string",
          "enum": [
            "overrides-wrapper"
          ]
        },
        {
          "description": "The target runner runs within the wrapper script. The command line used is `<wrapper> <target-runner> <test-binary> <args>`.",
          "type": "string",
          "enum": [
            "within-wrapper"
          ]
        },
        {
          "description": "The target runner runs around the wrapper script. The command line used is `<target-runner> <wrapper> <test-binary> <args>`.",
          "type": "string",
          "enum": [
            "around-wrapper"
          ]
        }
      ]
    }
  }
}
